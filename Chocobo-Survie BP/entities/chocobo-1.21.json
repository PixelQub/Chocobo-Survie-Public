"events":{
  "equiper:selle":{"add":{"component_groups":["a_selle"]}},
  "fin:selle":{"remove":{"component_groups":["a_selle"]}},
  "debuter:compagnion":{"add": {"component_groups": ["est_compagnion"]},"remove":{"component_groups":["est_explorateur"]}}, 
  "fin:compagnion":{"remove": {"component_groups": ["est_compagnion"]},"add":{"component_groups":["est_explorateur"]}},
  "debuter:apprivoiser" :{"remove": { "component_groups": [ "est_sauvage"] },"add": { "component_groups": ["est_apprivoiser","est_compagnion"] }  },
  "debuter:viellir" :{ "remove": { "component_groups": [ "est_bebe" ] },"add": { "component_groups": [ "est_adulte" ] }},

  "equiper:cuire" :{"add": { "component_groups": [ "armure_cuire","armure_support" ] },"remove": { "component_groups": [ "est_vie" ] }}, 
  "equiper:fer" :{ "add": { "component_groups": [ "armure_fer","armure_support" ] },"remove": { "component_groups": [ "est_vie" ] }},
  "equiper:or" :{"add": { "component_groups": [ "armure_or","armure_support" ] },"remove": { "component_groups": [ "est_vie" ] }},
  "equiper:diamand" :{"add": { "component_groups": [ "armure_diamand","armure_support" ] },"remove": { "component_groups": [ "est_vie" ] }},
  "equiper:copper" :{"add": { "component_groups": [ "armure_copper","armure_support" ] },"remove": { "component_groups": [ "est_vie" ] }},
  "equiper:netherite" :{"add": { "component_groups": [ "armure_netherite","armure_support" ] },"remove": { "component_groups": [ "est_vie" ] }},
  "fin:armure":{"remove": { "component_groups": [ "armure_cuire","armure_fer","armure_or","armure_diamand","armure_copper","armure_netherite","armure_support" ] },"add": { "component_groups": [ "est_vie" ] }},

  "natural_generation.jaune":{"add":{"component_groups":["est_adulte","est_sauvage","est_vie","var_jaune","est_type0"] } },
  "natural_generation.rouge":{"add":{"component_groups":["est_adulte","est_sauvage","est_vie","var_rouge","est_type1"] } },
  "natural_generation.bleu":{"add":{"component_groups":["est_adulte","est_sauvage","est_vie","var_bleu","est_type2"] } },

  "minecraft:entity_spawned":{
      "sequence": [
          {"add": 
              {"component_groups": ["est_adulte","est_sauvage","est_vie","famille_sauvage"]}},
          {"randomize": [
              {"weight":33,"add": { "component_groups": ["var_jaune","est_type0"] } },
              {"weight":33,"add": { "component_groups": ["var_rouge","est_type1"] } },
              {"weight":33,"add": { "component_groups": ["var_bleu","est_type2"] } }
              ]
          }
      ]
  },

