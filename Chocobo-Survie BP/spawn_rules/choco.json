          "value": "crimson_forest"
        }
      },

      {
        "minecraft:spawns_on_surface":{},
        "minecraft:brightness_filter":{"min":7,"max":15,"adjust_for_weather": false},
        "minecraft:weight": {"default": 2},
        "minecraft:herd": [{"min_size":1, "max_size":1, "event":"natural_generation.bleu"}],
        "minecraft:biome_filter": {"test": "has_biome_tag", "operator":"==", "value": "swamp"}
